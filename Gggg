-- UTILITY FUNCTIONS FOR TARGETING
local function GetPlayer(target)
    if not target or target == "me" then return {LocalPlayer} end
    if target == "all" then return Players:GetPlayers() end
    if target == "others" then
        local t = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(t, p) end
        end
        return t
    end
    local found = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #target) == target:lower() then table.insert(found, p) end
    end
    return found
end

